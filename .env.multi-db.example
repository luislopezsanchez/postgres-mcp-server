# ============================================================
#  CONFIGURACIÓN PARA MÚLTIPLES BASES DE DATOS
#  Copia este archivo como .env.multi-db y rellena tus datos
# ============================================================

# ----------------------------------------------------------
#  Base de datos: CLIENTES
# ----------------------------------------------------------
DB_CLIENTES_HOST=192.168.1.100
DB_CLIENTES_PORT=5432
DB_CLIENTES_NAME=clientes
DB_CLIENTES_USER=usuario_clientes
DB_CLIENTES_PASSWORD=contraseña_clientes

# ----------------------------------------------------------
#  Base de datos: INVENTARIO
# ----------------------------------------------------------
DB_INVENTARIO_HOST=192.168.1.100
DB_INVENTARIO_PORT=5432
DB_INVENTARIO_NAME=inventario
DB_INVENTARIO_USER=usuario_inventario
DB_INVENTARIO_PASSWORD=contraseña_inventario

# ----------------------------------------------------------
#  Base de datos: FACTURACION
# ----------------------------------------------------------
DB_FACTURACION_HOST=192.168.1.100
DB_FACTURACION_PORT=5432
DB_FACTURACION_NAME=facturacion
DB_FACTURACION_USER=usuario_facturacion
DB_FACTURACION_PASSWORD=contraseña_facturacion

# ----------------------------------------------------------
#  Puerto base — cada servicio suma 1 al anterior
#  clientes    → MCP_BASE_PORT + 0 = 8001
#  inventario  → MCP_BASE_PORT + 1 = 8002
#  facturacion → MCP_BASE_PORT + 2 = 8003
# ----------------------------------------------------------
MCP_BASE_PORT=8001
