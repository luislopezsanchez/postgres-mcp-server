# ============================================================
#  CONFIGURACIÓN MÍNIMA — copia este archivo como .env
#  y rellena los valores con tus credenciales reales
# ============================================================

POSTGRES_HOST=192.168.1.100       # IP o hostname del servidor PostgreSQL
POSTGRES_PORT=5432                # Puerto (5432 es el valor por defecto)
POSTGRES_DB=nombre_base_de_datos  # Nombre de la base de datos
POSTGRES_USER=usuario             # Usuario de PostgreSQL
POSTGRES_PASSWORD=contraseña      # Contraseña del usuario

# Modo de acceso al MCP:
#   restricted   → solo lectura, seguro para producción  ✅ recomendado
#   unrestricted → lectura y escritura, para desarrollo
ACCESS_MODE=restricted

# Puerto donde quedará disponible el servidor MCP
MCP_PORT=8000
