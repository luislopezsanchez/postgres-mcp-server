# ============================================================
#  CONFIGURACIÓN MÍNIMA — copia este archivo como .env
#  y rellena los valores con tus credenciales reales
# ============================================================

POSTGRES_HOST=172.17.0.1           # ⚠️ En Linux Docker NO usar host.docker.internal
                                    # Usar 172.17.0.1 (Docker bridge) o localhost
POSTGRES_PORT=5432                  # Puerto (5432 por defecto)
POSTGRES_DB=nombre_base_de_datos    # Nombre de la base de datos
POSTGRES_USER=usuario               # Usuario de PostgreSQL
POSTGRES_PASSWORD=contraseña        # Contraseña del usuario

# Modo de acceso al MCP:
#   restricted   → solo lectura (SELECT), timeout 30s
#   unrestricted → lectura/escritura, sin timeout
ACCESS_MODE=unrestricted

# Puerto donde quedará disponible el servidor MCP
MCP_PORT=8000

# ============================================================
#  REQUISITOS PREVIOS EN LA BASE DE DATOS (ver DEPLOY.md)
# ============================================================
# 1. pg_stat_statements en shared_preload_libraries + CREATE EXTENSION
# 2. hypopg instalado (apt o compilado desde source) + CREATE EXTENSION
# 3. ANALYZE después de instalar extensiones
# 4. GRANT ALL al usuario MCP en tablas/secuencias
